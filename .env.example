# =============================================================================
# CICD Stack Environment Configuration
# =============================================================================
# IMPORTANT: Copy this file to .env.local for local overrides.
# Never commit secrets to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Global
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=cicd-stack
DOCKER_RESTART_POLICY=unless-stopped

# -----------------------------------------------------------------------------
# GitLab
# -----------------------------------------------------------------------------
GITLAB_HOME=/srv/gitlab
GITLAB_HOSTNAME=gitlab.local
GITLAB_HTTP_PORT=8929
GITLAB_SSH_PORT=2224
GITLAB_ROOT_PASSWORD=CHANGE_ME
GITLAB_SHARED_RUNNERS_REGISTRATION_TOKEN=CHANGE_ME

# -----------------------------------------------------------------------------
# PostgreSQL (shared: GitLab, TeamCity)
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=teamcity

# GitLab DB
GITLAB_DB_USER=gitlab
GITLAB_DB_PASSWORD=CHANGE_ME
GITLAB_DB_NAME=gitlabhq_production

# TeamCity DB
TEAMCITY_DB_USER=teamcity
TEAMCITY_DB_PASSWORD=CHANGE_ME
TEAMCITY_DB_NAME=teamcity

# -----------------------------------------------------------------------------
# TeamCity
# -----------------------------------------------------------------------------
TEAMCITY_SERVER_PORT=8111
TEAMCITY_SERVER_MEM_OPTS=-Xmx2g -XX:MaxPermSize=270m -XX:ReservedCodeCacheSize=640m

# -----------------------------------------------------------------------------
# Octopus Deploy
# -----------------------------------------------------------------------------
OCTOPUS_SERVER_PORT=8080
OCTOPUS_ADMIN_USERNAME=admin
OCTOPUS_ADMIN_PASSWORD=CHANGE_ME
OCTOPUS_DB_CONNECTION_STRING=Server=mssql,1433;Database=OctopusDeploy;User Id=sa;Password=CHANGE_ME;TrustServerCertificate=true

# MSSQL (for Octopus Deploy)
MSSQL_SA_PASSWORD=CHANGE_ME
MSSQL_PID=Express

# -----------------------------------------------------------------------------
# ClickHouse
# -----------------------------------------------------------------------------
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=CHANGE_ME

# -----------------------------------------------------------------------------
# Prometheus
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=30d
PROMETHEUS_RETENTION_SIZE=10GB

# -----------------------------------------------------------------------------
# Grafana
# -----------------------------------------------------------------------------
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
GF_INSTALL_PLUGINS=grafana-clickhouse-datasource
